method = 'number',
tl.cex = 0.5,
tl.srt = 45,
cl.cex = 0.8,
number.cex = 0.7,
cex.main = 0.8,
mar = c(0,0,2,0),
title = "Correlation plot for the numeric fields in the gymn data")
#Drop the potentially irrelevant columns
exercise_clean_data_reduced = subset(exercise_clean_data,
select=-c(bmi,
height_m,
max_bpm,
resting_bpm))
glimpse(exercise_clean_data_reduced, width = 5)
#First restructure the data to allow easy creation of the plots
cols_to_pivot = subset(exercise_clean_data_reduced,
select = c(gender, experience_level, workout_type))
exercise_data_box = pivot_longer(exercise_clean_data_reduced,
cols = where(is.factor),
names_to = "factor_variables",
values_to = "factor_values")
#Now create the boxplots
ggplot(data= exercise_data_box, aes(x = factor_values, y = calories_burned)) +
geom_boxplot() +
facet_grid( ~factor_variables)+
labs(title = 'Boxplots to visually inspect the impact of factor variable',
x = "Experience Level, Gender and Workout Type",
y = "Calories Burned")+
theme(axis.text.x = element_text(angle = 45))
exercise_full_model = lm(calories_burned~., data=exercise_clean_data_reduced)
#Display the coefficients
summary(exercise_full_model)
#Create a function to help in finding loocv_rmse
find_loocv_rmse = function(model){
sqrt(mean((resid(model)/(1-hatvalues(model)))^2))
}
#Use it the cross-validation function on the full model
full_rmse = find_loocv_rmse(exercise_full_model)[1]
sprintf("The Loocv rmse is: %.2f ", full_rmse)
data.frame(vif(exercise_full_model)[,1])
#Make a dataframe with the statistical tests for the assumptions
bp_shapiro_table = function(model) {
test_names = c("bp-test", "shapiro-test")
test_p_values = c(bptest(model)$p.value[1],
shapiro.test(resid(model))$p.value[1])
data.frame(row.names = test_names, test_p_values)
}
bp_shapiro_table(exercise_full_model)
#Fit the model without the variables that are suspicious of collinearity
eight_pred_model = lm(calories_burned ~ .,
data =   subset(
exercise_clean_data_reduced,
select = -c(experience_level, fat_percentage)
))
#Check the results for any improvements
summary(eight_pred_model)
data.frame(vif=vif(eight_pred_model)[,1])
#Let's fit the model
four_pred_model = (
lm(
calories_burned ~ age + gender + avg_bpm + session_duration_hours,
data = exercise_clean_data_reduced
)
)
#We check on how it has changed
summary(four_pred_model)
bp_shapiro_table(four_pred_model)
four_poly_model = lm(
(calories_burned) ~ gender + poly(age, 2, raw = TRUE) +
poly(avg_bpm, 2, raw = TRUE) +
poly(session_duration_hours, 2, raw =TRUE),
data = subset(
exercise_clean_data_reduced,
select = c("gender", "age", "avg_bpm", "session_duration_hours",      "calories_burned")
)
)
summary(four_poly_model)
poly_model_log = lm(
log(calories_burned) ~ gender + poly(age, 2, raw = TRUE) +
poly(avg_bpm, 2, raw = TRUE) +
poly(session_duration_hours, 2, raw =TRUE),
data = subset(
exercise_clean_data_reduced,
select = c("gender", "age", "avg_bpm", "session_duration_hours",      "calories_burned")
)
)
summary(poly_model_log)
bp_shapiro_table(poly_model_log)
response_only_transf_model = (
lm(
log(calories_burned) ~ age + gender + avg_bpm + session_duration_hours,
data = exercise_clean_data_reduced
)
)
#We check on how it has changed
summary(response_only_transf_model)
n = length(resid(poly_model_log))
poly_log_model_bic = step(poly_model_log,
direction = "backward",
trace = FALSE,
k=log(n))
summary(poly_log_model_bic)
interaction_model = lm (calories_burned~age * gender * avg_bpm * session_duration_hours,
data = exercise_clean_data_reduced )
summary(interaction_model)
#Create a function to help in finding loocv_rmse
